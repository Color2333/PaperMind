# ==========================================
# PaperMind 环境配置示例
# ==========================================
#
# 使用说明：
# - 本地开发：复制为 .env（根目录）
# - Docker部署：复制为 .env（根目录）
#
# 必须配置项：至少填写一个 LLM API Key
# ==========================================

# ==========================================
# 基础配置
# ==========================================
APP_ENV=production
APP_NAME=PaperMind API
API_HOST=0.0.0.0
API_PORT=8000

# 数据库路径
# - 本地开发：sqlite:///./data/papermind.db
# - Docker部署：sqlite:////app/data/papermind.db
# - PostgreSQL（见 infra/docker-compose.postgres.yml，compose 已内置 postgres 服务）：
#     DATABASE_URL=postgresql+psycopg2://papermind:papermind@postgres:5432/papermind
# 切库流程见 scripts/migrate_sqlite_to_pg.py 顶部文档注释
DATABASE_URL=sqlite:///./data/papermind.db

# SQLite → PG 迁移专用（仅运行 scripts/migrate_sqlite_to_pg.py 时使用）
# 指向"原 SQLite 文件路径"，迁移完即可清空
SOURCE_DATABASE_URL=

# 存储路径
PDF_STORAGE_ROOT=./data/papers
BRIEF_OUTPUT_ROOT=./data/briefs

# CORS 配置
# - 本地开发：*
# - Docker部署：http://localhost:3002,http://127.0.0.1:3002
CORS_ALLOW_ORIGINS=*

# ==========================================
# LLM API 配置（必须填写至少一个！）
# ==========================================
# LLM Provider: xiaomi / zhipu / openai / anthropic
LLM_PROVIDER=xiaomi

# 小米 MiMo（默认推荐，OpenAI 兼容）
# Base URL: https://token-plan-cn.xiaomimimo.com/v1
XIAOMI_API_KEY=

# ZhipuAI 智谱（备选）
ZHIPU_API_KEY=

# OpenAI（可选）
OPENAI_API_KEY=

# Anthropic（可选）
ANTHROPIC_API_KEY=

# 外部 API
SEMANTIC_SCHOLAR_API_KEY=
OPENALEX_EMAIL=

# 模型配置（小米 MiMo 默认）
LLM_MODEL_SKIM=mimo-v2-omni
LLM_MODEL_DEEP=mimo-v2.5-pro
LLM_MODEL_VISION=mimo-v2.5
LLM_MODEL_FALLBACK=mimo-v2.5-pro

# Embedding 独立 provider（小米 MiMo 不提供 embedding，默认走阿里百炼 DashScope）
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_DIMENSIONS=1024

# ==========================================
# 成本管控
# ==========================================
COST_GUARD_ENABLED=true
PER_CALL_BUDGET_USD=0.05
DAILY_BUDGET_USD=2.0
SKIM_SCORE_THRESHOLD=0.65

# ==========================================
# 站点认证配置
# ==========================================
# 站点密码，为空则禁用认证（公开访问）
AUTH_PASSWORD=

# JWT 密钥（生产环境请修改为随机字符串）
AUTH_SECRET_KEY=papermind-secret-key-change-in-production

# MCP server 鉴权 token（供 hermes 等外部 agent 接入 /mcp 端点，独立静态 token 免续期）
# 生成: openssl rand -hex 32；留空则 MCP 端点不鉴权（仅开发用）
MCP_AUTH_TOKEN=

# ==========================================
# Demo 站配置（公网部署时启用）
# ==========================================
DEMO_MODE=false
DEMO_IP_LIMIT_PER_HOUR=30
DEMO_GLOBAL_RPM=50

# ==========================================
# SMTP 邮件配置（推送通知需要）
# ==========================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
NOTIFY_DEFAULT_TO=

# ==========================================
# 智能调度配置（UTC 时间）
# ==========================================
# 每日简报：UTC 4 点 = 北京时间 12 点
DAILY_CRON=0 4 * * *

# 每周图谱：UTC 周日 22 点 = 北京时间周一 6 点
WEEKLY_CRON=0 22 * * 0

# ==========================================
# Worker 重试配置
# ==========================================
WORKER_RETRY_MAX=3
WORKER_RETRY_BASE_DELAY=5.0
